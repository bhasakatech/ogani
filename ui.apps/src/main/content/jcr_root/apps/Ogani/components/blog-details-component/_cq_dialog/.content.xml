<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Blog Details Configuration"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <search-settings
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Search Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <search-placeholder
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Search Placeholder"
                                name="./searchPlaceholder"
                                value="Search..."/>
                            <min-search-length
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldLabel="Minimum Characters to Search"
                                name="./minSearchLength"
                                value="4"/>
                        </items>
                    </search-settings>
                    <sidebar-requirements
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Sidebar Configuration"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <category-root-path
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Category Tags Root Path"
                                name="./categoryRootPath"
                                rootPath="/content/cq:tags"/>
                            <recent-news-limit
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldLabel="Recent Blog Pages Limit"
                                name="./recentBlogPagesLimit"
                                value="4"/>
                            <blog-parent-path
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Blog Parent Path"
                                name="./blogParentPath"
                                rootPath="/content"/>
                        </items>
                    </sidebar-requirements>
                    <rightside-requirements
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Right Side Configuration"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <blog-detail-path
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Blog Details Path"
                                name="./blogDetailPath"
                                rootPath="/content/Ogani/us/en"/>
                        </items>
                    </rightside-requirements>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
