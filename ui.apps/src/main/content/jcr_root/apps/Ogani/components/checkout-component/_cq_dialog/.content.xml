<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Checkout Component Dialog"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <checkout-title
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Checkout Page Title"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <checkout-header-title
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Checkout Title"
                                name="./checkoutTitle"/>
                        </items>
                    </checkout-title>
                    <billing-details
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Billing Details"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <first-name
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="First Name"
                                name="./firstName"/>
                            <last-name
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Last Name"
                                name="./lastName"/>
                            <country
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Country"
                                name="./country"/>
                            <address
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Address"
                                name="./address"/>
                            <address-apartment
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                name="./apartment"/>
                            <town-city
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Town/City"
                                name="./townOrCity"/>
                            <country-state
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="State/Country"
                                name="./stateOrCountry"/>
                            <zip-code
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldLabel="Postcode/ZIP"
                                name="./zipCode"/>
                            <phone
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Phone"
                                name="./phone"/>
                            <email
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Email"
                                name="./email"/>
                        </items>
                    </billing-details>
                    <placeholder-details
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Placeholder Details"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <first-name
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="First Name Placeholder"
                                name="./firstNamePlaceholder"/>
                            <last-name
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Last Name Placeholder"
                                name="./lastNamePlaceholder"/>
                            <country
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Country Placeholder"
                                name="./countryPlaceholder"/>
                            <address
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Address Placeholder"
                                name="./addressPlaceholder"/>
                            <address-apartment
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                name="./apartmentPlaceholder"/>
                            <town-city
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Town/City Placeholder"
                                name="./townOrCityPlaceholder"/>
                            <country-state
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="State/Country Placeholder"
                                name="./stateOrCountryPlaceholder"/>
                            <zip-code
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Postcode/ZIP Placeholder"
                                name="./zipCodePlaceholder"/>
                            <phone
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Phone Placeholder"
                                name="./phonePlaceholder"/>
                            <email
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Email Placeholder"
                                name="./emailPlaceholder"/>
                        </items>
                    </placeholder-details>
                    <order-summary
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Order Summary"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <cartPath
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Cart Page Path"
                                name="./cartPath"
                                required="{Boolean}true"
                                rootPath="/content"/>
                            <placeOrderLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Place Order Button Text"
                                name="./placeOrderLabel"
                                value="PLACE ORDER"/>
                            <orderTitle
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Order Section Title"
                                name="./orderTitle"
                                value="Your Order"/>
                            <subtotalLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Subtotal Label"
                                name="./subtotalLabel"
                                value="Subtotal"/>
                            <finalTotalLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Final Total Label"
                                name="./finalTotalLabel"
                                value="Total"/>
                            <payment-desc
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                fieldLabel="Payment Description"
                                name="./paymentDescription"/>
                        </items>
                    </order-summary>
                    <account-order-details
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Account and Order Details"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <account-info
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                fieldLabel="Account Information"
                                name="./accountInformation"/>
                            <account-password
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldDescription="Password must contains alpha numeric characters."
                                fieldLabel="Account Password"
                                name="./accountPassword"/>
                            <order-notes
                                jcr:primaryType="nt:unstructured"
                                fieldLabel="Order Notes"
                                name="./orderNotes"/>
                            <account-password-placeholder
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Account Password Placeholder"
                                name="./accountPasswordPlaceholder"/>
                            <order-notes-placeholder
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                fieldLabel="Order Notes Placeholder"
                                name="./orderNotesPlaceholder"/>
                        </items>
                    </account-order-details>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
